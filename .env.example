# Database (docs/build/03-database-foundation.md)
# Local dev currently runs against Docker Postgres (docker-compose.yml) — see README for setup.
# Will point at Neon once that's wired up; same variable name, just a different value later.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/partsbench"

# Cloudflare R2 (docs/build/07-photo-pipeline.md)
# Local dev runs against Docker MinIO (docker-compose.yml), same pattern as Postgres/Neon.
# R2_ENDPOINT is only set for MinIO/local S3-compatible stores — omit it for real R2 and the
# client derives the endpoint from R2_ACCOUNT_ID instead (https://<account_id>.r2.cloudflarestorage.com).
R2_ENDPOINT="http://localhost:9000"
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=partsbench

# Auth (docs/build/04-auth.md)
# AUTH_PASSWORD_HASH: generate with `npm run auth:hash-password` (never store the plaintext password).
#   The script already escapes `$` as `\$` for you — paste its output as-is. Next.js expands
#   $VARIABLE references in .env* files, and bcrypt hashes are full of `$`-delimited segments,
#   so an unescaped hash gets silently corrupted at load time (looks fine in the file, wrong at runtime).
# SESSION_SECRET: any random string 32+ chars, e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_PASSWORD_HASH=
SESSION_SECRET=
