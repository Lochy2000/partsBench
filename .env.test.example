# Copy to .env.test for local integration test runs (see docs/build/03-database-foundation.md).
# Points at the "partsbench_test" database created by docker-compose (docker/init-test-db.sql),
# kept separate from dev data so running tests never touches what's seeded locally.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/partsbench_test"

# Photo pipeline tests (docs/build/07-photo-pipeline.md) — points at the "partsbench-test"
# MinIO bucket, kept separate from the dev bucket for the same reason as the test database.
R2_ENDPOINT="http://localhost:9000"
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET=partsbench-test
